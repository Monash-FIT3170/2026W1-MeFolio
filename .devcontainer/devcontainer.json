{
  "name": "MeFolio-Dev-Env",
  "dockerComposeFile": "../docker-compose.yaml",
  "service": "app",
  "remoteUser": "root",

  "workspaceFolder": "/workspace/mefolio",

  "postCreateCommand": "meteor npm install && meteor --version",

  "forwardPorts": [3000],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode"
      ]
    }
  }
}